print "Enter first number:"
input a

print "Enter second number:"
input b

print "Choose operator:\n"
print "0: +"
print "1: -"
print "2: *"
print "3: /"
input op

let result

if op == 0 {
    result = a + b
} elif op == 1 {
    result = a - b
} elif op == 2 {
    result = a * b
} elif op == 3 {
    if b == 0 {
        print "Error: Division by zero!"
        exit 1
    }
    result = a / b
} else {
    print "Error: Invalid operator!"
    exit 1
}

print "The result is:"
print result
exit 0
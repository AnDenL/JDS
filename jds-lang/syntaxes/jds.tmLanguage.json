{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "JDS",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#functions" },
    { "include": "#variables" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "match": "//.*",
          "name": "comment.line.double-slash.jds"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(let|if|elif|else|while|module)\\b",
          "name": "keyword.control.jds"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b(exit|print|println|input|exec)\\b",
          "name": "support.function.builtin.jds"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "match": "\\b(argc)\\b",
          "name": "variable.language.jds"
        },
        {
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
          "name": "variable.other.jds"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.jds",
          "patterns": [
            { "match": "\\\\.", "name": "constant.character.escape.jds" }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "\\b\\d+\\b",
          "name": "constant.numeric.integer.jds"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "match": "==|!=|<=|>=|<|>|=|\\+|-|\\*|/|%",
          "name": "keyword.operator.jds"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "match": "[{}]",
          "name": "punctuation.definition.block.jds"
        },
        {
          "match": "[()]",
          "name": "punctuation.definition.parameters.jds"
        }
      ]
    }
  },
  "scopeName": "source.jds"
}
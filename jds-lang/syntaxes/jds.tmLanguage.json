{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "JDS",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "match": "//.*",
          "name": "comment.line.double-slash.jds"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(let|if|elif|else|while|exit|print|println|input|exec|module)\\b",
          "name": "keyword.control.jds"
        },
        {
          "match": "\\b(argc)\\b",
          "name": "variable.language.jds"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.jds",
          "patterns": [
            { "match": "\\\\.", "name": "constant.character.escape.jds" }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "\\b\\d+\\b",
          "name": "constant.numeric.integer.jds"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "match": "==|<|>|=|\\+|-|\\*|/|%",
          "name": "keyword.operator.jds"
        }
      ]
    }
  },
  "scopeName": "source.jds"
}